/* 高斯模糊玻璃质感变量 */
.tabbar-wrapper {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  
  /* CSS 变量定义 */
  --glass-bg-opacity: 0;
  --glass-tint-color: 255, 255, 255;
  --glass-blur: 40rpx;
  --glass-border-opacity: 0.25;
  --glass-reflection-opacity: 0.15;
  --active-glow-color: 97, 144, 232;
  --active-glow-opacity: 0;
}

.svg-filters {
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 0;
  pointer-events: none;
}

.tabbar {
  margin: 0 30rpx;
  margin-bottom: 40rpx;
  height: 120rpx;
  border-radius: 48rpx;
  position: relative;
  overflow: hidden;
  isolation: isolate;
  box-shadow: 
    0 24rpx 64rpx rgba(0, 0, 0, 0.12),
    0 12rpx 24rpx rgba(0, 0, 0, 0.08),
    0 4rpx 8rpx rgba(0, 0, 0, 0.04);
  filter: url(#liquid-glass-distortion);
}

.glass-background {
  position: absolute;
  inset: 0;
  z-index: 0;
  border-radius: 48rpx;
  /* 高斯模糊玻璃效果 */
  background: rgba(var(--glass-tint-color), var(--glass-bg-opacity));
  backdrop-filter: 
    blur(var(--glass-blur)) 
    saturate(180%)
    brightness(1.1);
  -webkit-backdrop-filter: 
    blur(var(--glass-blur)) 
    saturate(180%)
    brightness(1.1);
  /* 玻璃边框 */
  border: 1rpx solid rgba(255, 255, 255, var(--glass-border-opacity));
  /* 柔和内阴影增强玻璃质感 */
  box-shadow: 
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5),
    inset 0 -1rpx 0 rgba(255, 255, 255, 0.2);
}

.glass-inner-shadow {
  position: absolute;
  inset: 0;
  z-index: 1;
  border-radius: 48rpx;
  /* 玻璃内部光影 */
  box-shadow: 
    inset 0 2rpx 20rpx rgba(255, 255, 255, 0.4),
    inset 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  pointer-events: none;
}

.glass-reflection {
  position: absolute;
  inset: 0;
  z-index: 2;
  border-radius: 48rpx;
  /* 玻璃反光效果 */
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, var(--glass-reflection-opacity)) 0%,
    rgba(255, 255, 255, 0.08) 30%,
    rgba(255, 255, 255, 0.03) 60%,
    transparent 100%
  );
  pointer-events: none;
  opacity: 1;
}

.tabs-container {
  position: relative;
  z-index: 10;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  padding: 0 8rpx;
}

.tab-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #374151;
  position: relative;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  -webkit-user-select: none;
  user-select: none;
}

.tab-item.active {
  color: #6190e8;
  transform: translateY(-4rpx);
}

.tab-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  -webkit-tap-highlight-color: transparent;
}

.tab-icon {
  width: 46rpx;
  height: 46rpx;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  z-index: 2;
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  -webkit-user-select: none;
  user-select: none;
  pointer-events: none;
}

.tab-item.active .tab-icon {
  transform: scale(1.15);
}

.icon-glow {
  display: none;
}

.tab-text {
  font-size: 22rpx;
  margin-top: 6rpx;
  font-weight: 500;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  /* 增强文字可读性 */
  text-shadow: 
    0 1rpx 3rpx rgba(255, 255, 255, 0.9),
    0 0 1rpx rgba(0, 0, 0, 0.2);
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  -webkit-user-select: none;
  user-select: none;
  pointer-events: none;
}

.tab-item.active .tab-text {
  font-weight: 600;
  text-shadow: 
    0 1rpx 3rpx rgba(255, 255, 255, 0.9),
    0 0 1rpx rgba(0, 0, 0, 0.2);
}

.tab-item:hover {
  transform: translateY(-2rpx);
}

.tab-item.active:hover {
  transform: translateY(-6rpx);
}

.tab-item:active {
  transform: translateY(0rpx) scale(0.98);
  transition: all 0.1s ease;
}

.safe-area {
  height: 0;
  background: transparent;
} 

.tabbar-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  z-index: 20;
  background: transparent;
  backdrop-filter: blur(2rpx);
}

@media (max-width: 750rpx) {
  .tabbar {
    margin: 0 20rpx;
    height: 110rpx;
  }
  
  .tab-icon {
    width: 42rpx;
    height: 42rpx;
  }
  
  .tab-text {
    font-size: 20rpx;
  }
  
  .tab-icon-wrapper {
    width: 50rpx;
    height: 50rpx;
  }
}

@media (prefers-color-scheme: dark) {
  .tabbar-wrapper {
    --glass-bg-opacity: 0;
    --glass-tint-color: 30, 30, 35;
    --glass-border-opacity: 0.15;
    --glass-reflection-opacity: 0.08;
  }
  
  .glass-background {
    backdrop-filter: 
      blur(40rpx) 
      saturate(180%)
      brightness(0.9);
    -webkit-backdrop-filter: 
      blur(40rpx) 
      saturate(180%)
      brightness(0.9);
    box-shadow: 
      inset 0 1rpx 0 rgba(255, 255, 255, 0.1),
      inset 0 -1rpx 0 rgba(255, 255, 255, 0.05);
  }
  
  .tab-item {
    color: #d1d5db;
  }
  
  .tab-item.active {
    color: #93c5fd;
  }
}

@media (prefers-reduced-motion: reduce) {
  .tab-item,
  .tab-icon,
  .tab-text,
  .icon-glow {
    transition: none;
    animation: none;
  }
}

@media (prefers-contrast: high) {
  .glass-background {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: none;
  }
  
  .glass-reflection {
    opacity: 0.3;
  }
  
  .tab-item {
    color: #000;
  }
  
  .tab-item.active {
    color: #0066cc;
  }
}