<view class="tabbar-wrapper">
  <view class="svg-filters">
    <view style="position: absolute; width: 0; height: 0; overflow: hidden;">
      <svg xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="liquid-glass-distortion" x="-20%" y="-20%" width="140%" height="140%">
            <feTurbulence baseFrequency="0.008 0.008" numOctaves="3" result="noise" />
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G" />
          </filter>
          
          <filter id="inner-shadow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="4" result="blur"/>
            <feOffset in="blur" dx="0" dy="2" result="offsetBlur"/>
            <feFlood flood-color="rgba(255,255,255,0.8)" result="shadowColor"/>
            <feComposite in="shadowColor" in2="offsetBlur" operator="in" result="shadowBlur"/>
            <feComposite in="SourceGraphic" in2="shadowBlur" operator="over"/>
          </filter>
          
          <filter id="edge-glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
          
          <linearGradient id="glass-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:rgba(255,255,255,0.8);stop-opacity:1" />
            <stop offset="30%" style="stop-color:rgba(255,255,255,0.4);stop-opacity:1" />
            <stop offset="70%" style="stop-color:rgba(255,255,255,0.1);stop-opacity:1" />
            <stop offset="100%" style="stop-color:rgba(255,255,255,0.05);stop-opacity:1" />
          </linearGradient>
        </defs>
      </svg>
    </view>
  </view>

  <view class="tabbar" catchtouchmove="true">
    <view class="glass-background"></view>
    <view class="glass-inner-shadow"></view>
    <view class="glass-reflection"></view>
    
    <view class="tabs-container">
      <block wx:for="{{tabs}}" wx:key="pagePath">
        <view class="tab-item {{selected === index ? 'active' : ''}}" data-index="{{index}}" data-url="/{{item.pagePath}}" bindtap="onTap" hover-class="none">
          <view class="tab-icon-wrapper" hover-class="none">
            <image class="tab-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" mode="aspectFit" hover-class="none" />
            <view wx:if="{{selected === index}}" class="icon-glow"></view>
          </view>
          <text class="tab-text">{{item.text}}</text>
        </view>
      </block>
    </view>
  </view>
  
  <view wx:if="{{interactionLocked}}" class="tabbar-mask" catchtap="noop" catchtouchmove="noop" />
</view> 