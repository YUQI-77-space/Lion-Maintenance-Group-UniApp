/* components/loading-state/index.wxss */
@import "../../styles/variables.wxss";

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
}

/* 加载动画 */
.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner-ring {
  border: 3rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 尺寸 */
.loading-spinner.small .spinner-ring {
  width: 32rpx;
  height: 32rpx;
  border-width: 2rpx;
}

.loading-spinner.normal .spinner-ring {
  width: 48rpx;
  height: 48rpx;
}

.loading-spinner.large .spinner-ring {
  width: 64rpx;
  height: 64rpx;
  border-width: 4rpx;
}

/* 加载文字 */
.loading-text {
  margin-top: var(--space-sm);
  font-size: var(--font-caption);
  color: var(--text-muted);
}
