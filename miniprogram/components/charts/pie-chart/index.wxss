/* components/charts/pie-chart/index.wxss */
.chart-root {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.chart-canvas-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
}

.pie-canvas {
  display: block;
}

.legend-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
  align-items: center;
}

.legend-summary {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.summary-primary {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.summary-sub {
  font-size: 22rpx;
  color: #888;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.legend-item + .legend-item {
  margin-top: 12rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-texts {
  display: flex;
  flex-direction: column;
}

.legend-name {
  font-size: 26rpx;
  color: #333;
}

.legend-sub {
  font-size: 22rpx;
  color: #888;
}

