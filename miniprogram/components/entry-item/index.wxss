/* components/entry-item/index.wxss */
@import "../../styles/variables.wxss";

.entry-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-md);
  background: var(--bg-card);
  border-radius: var(--radius-card);
  transition: opacity 150ms ease;
}

.entry-item:active { opacity: 0.7; }

/* 图标 */
.entry-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: var(--space-xs);
}

.entry-icon-text {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: var(--space-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* 标题 */
.entry-title {
  font-size: var(--font-caption);
  color: var(--text-primary);
  margin-top: var(--space-xs);
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 描述 */
.entry-desc {
  font-size: var(--font-hint);
  color: var(--text-secondary);
  margin-top: 4rpx;
  text-align: center;
}

/* 徽章 */
.entry-badge {
  position: absolute;
  top: var(--space-xs);
  right: var(--space-xs);
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: var(--danger);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-badge-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--danger);
  border-radius: 50%;
}

/* 箭头 */
.entry-arrow {
  position: absolute;
  right: var(--space-sm);
  top: 50%;
  transform: translateY(-50%);
  font-size: var(--font-body);
  color: var(--text-muted);
}

/* 变体 */
.entry-item-small {
  padding: var(--space-sm);
}

.entry-item-small .entry-icon {
  width: 44rpx;
  height: 44rpx;
}

.entry-item-small .entry-title {
  font-size: var(--font-hint);
}

.entry-item-large {
  padding: var(--space-lg);
}

.entry-item-large .entry-icon {
  width: 72rpx;
  height: 72rpx;
}

.entry-item-large .entry-title {
  font-size: var(--font-body);
}

/* 功能入口 - 强调品牌色 */
.entry-item-primary .entry-title {
  color: var(--primary);
  font-weight: 600;
}
