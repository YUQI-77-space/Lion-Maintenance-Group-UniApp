<!-- 空状态组件 -->
<view class="empty-state {{customClass}}">
  <!-- 图标 -->
  <view class="empty-icon-wrap" wx:if="{{icon || showDefaultIcon}}">
    <image 
      wx:if="{{icon}}" 
      class="empty-icon" 
      src="{{icon}}" 
      mode="aspectFit">
    </image>
    <text wx:if="{{!icon && showDefaultIcon}}" class="empty-icon-text">{{ defaultIcon }}</text>
  </view>
  
  <!-- 主文字 -->
  <text class="empty-text" wx:if="{{text}}">{{ text }}</text>
  
  <!-- 描述 -->
  <text class="empty-desc" wx:if="{{desc}}">{{ desc }}</text>
  
  <!-- 操作按钮 -->
  <view class="empty-action" wx:if="{{actionText}}" bindtap="onAction">
    <view class="btn btn-primary {{actionClass}}">{{ actionText }}</view>
  </view>
</view>
