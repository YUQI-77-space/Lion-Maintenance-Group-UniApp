/* components/empty-state/index.wxss */
@import "../../styles/variables.wxss";

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-md);
}

/* 图标 */
.empty-icon-wrap {
  margin-bottom: var(--space-md);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.5;
}

.empty-icon-text {
  font-size: 120rpx;
  opacity: 0.4;
}

/* 主文字 */
.empty-text {
  font-size: var(--font-body);
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: var(--space-xs);
}

/* 描述 */
.empty-desc {
  font-size: var(--font-caption);
  color: var(--text-muted);
  text-align: center;
  max-width: 500rpx;
}

/* 操作按钮 */
.empty-action {
  margin-top: var(--space-lg);
}

/* 变体 */
.empty-state-small {
  padding: var(--space-lg) var(--space-md);
}

.empty-state-small .empty-icon {
  width: 80rpx;
  height: 80rpx;
}

.empty-state-small .empty-icon-text {
  font-size: 80rpx;
}

.empty-state-small .empty-action {
  margin-top: var(--space-md);
}
