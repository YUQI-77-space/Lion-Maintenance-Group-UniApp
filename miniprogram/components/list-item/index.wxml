<!-- 列表项组件 -->
<view 
  class="list-item {{customClass}}" 
  bindtap="onTap">
  
  <!-- 左侧图标/头像 -->
  <view class="list-item-left" wx:if="{{icon || avatar}}">
    <image 
      wx:if="{{avatar}}" 
      class="list-item-avatar" 
      src="{{avatar}}" 
      mode="aspectFill">
    </image>
    <text wx:if="{{icon && !avatar}}" class="list-item-icon">{{ icon }}</text>
  </view>
  
  <!-- 主内容区 -->
  <view class="list-item-content {{contentClass}}">
    <view class="list-item-main">
      <text class="list-item-title">{{ title }}</text>
      <text class="list-item-label" wx:if="{{label}}">{{ label }}</text>
    </view>
    <text class="list-item-desc" wx:if="{{desc}}">{{ desc }}</text>
  </view>
  
  <!-- 右侧内容 -->
  <view class="list-item-right" wx:if="{{value || showArrow}}">
    <text class="list-item-value" wx:if="{{value}}">{{ value }}</text>
    <text class="list-item-arrow" wx:if="{{showArrow}}">></text>
  </view>
  
  <!-- 开关 -->
  <switch 
    wx:if="{{showSwitch}}" 
    class="list-item-switch" 
    checked="{{checked}}"
    disabled="{{disabled}}"
    bindchange="onSwitchChange">
  </switch>
</view>
