/* components/feedback-modal/index.wxss */

.feedback-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 40rpx;
  box-sizing: border-box;
}

.feedback-modal-container {
  width: 100%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-50rpx) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.modal-header {
  padding: 40rpx 40rpx 20rpx 40rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
}

.modal-content {
  padding: 30rpx 40rpx;
  min-height: 120rpx;
}

.modal-details {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.8;
  display: block;
  word-wrap: break-word;
  word-break: break-all;
  white-space: pre-wrap; /* 保留换行符和空格 */
  text-align: left; /* 左对齐 */
}

.modal-footer {
  padding: 20rpx 40rpx 40rpx 40rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #007aff 0%, #0056cc 100%);
  color: #ffffff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.3);
}

.confirm-btn:not(.confirming):active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.4);
}

.confirm-btn.confirming {
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  cursor: not-allowed;
}

/* 响应式适配 */
@media (max-width: 480rpx) {
  .feedback-modal-overlay {
    padding: 20rpx;
  }
  
  .modal-header {
    padding: 30rpx 30rpx 15rpx 30rpx;
  }
  
  .modal-title {
    font-size: 32rpx;
  }
  
  .modal-content {
    padding: 20rpx 30rpx;
  }
  
  .modal-details {
    font-size: 28rpx;
  }
  
  .modal-footer {
    padding: 15rpx 30rpx 30rpx 30rpx;
  }
  
  .confirm-btn {
    height: 80rpx;
    font-size: 30rpx;
  }
}
