<!-- 卡片组件 -->
<view 
  class="card {{customClass}} {{shadow ? 'card-shadow' : ''}}" 
  bindtap="onTap">
  <view class="card-header" wx:if="{{title || subtitle}}">
    <view class="card-header-left">
      <text class="card-title" wx:if="{{title}}">{{ title }}</text>
      <text class="card-subtitle" wx:if="{{subtitle}}">{{ subtitle }}</text>
    </view>
    <view class="card-header-right" wx:if="{{extra}}">
      <text class="card-extra">{{ extra }}</text>
    </view>
  </view>
  <view class="card-body">
    <slot></slot>
  </view>
  <view class="card-footer" wx:if="{{footer}}">
    <text class="card-footer-text">{{ footer }}</text>
  </view>
</view>
