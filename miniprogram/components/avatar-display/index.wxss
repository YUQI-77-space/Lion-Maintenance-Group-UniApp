/* components/avatar-display/index.wxss */

.avatar-container {
  position: relative;
  display: inline-block;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f5f5f5;
}

/* 尺寸变体 */
.avatar-small {
  width: 60rpx;
  height: 60rpx;
}

.avatar-medium {
  width: 100rpx;
  height: 100rpx;
}

.avatar-large {
  width: 150rpx;
  height: 150rpx;
}

.avatar-xlarge {
  width: 200rpx;
  height: 200rpx;
}

/* 边框样式 */
.with-border {
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 可点击样式 */
.clickable {
  cursor: pointer;
  transition: transform 0.2s ease;
}

.clickable:hover {
  transform: scale(1.05);
}

.clickable:active {
  transform: scale(0.95);
}

/* 头像图片 */
.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

/* 加载状态 */
.avatar-loading {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
}

.loading-spinner {
  width: 30%;
  height: 30%;
  border: 3rpx solid #e0e0e0;
  border-top: 3rpx solid #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 点击覆盖层 */
.click-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
  border-radius: 50%;
}

.clickable .click-overlay:hover {
  opacity: 1;
}

.click-icon {
  color: white;
  font-size: 24rpx;
}

/* 特殊场景样式 */
.avatar-container.profile-avatar {
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.2);
}

.avatar-container.list-avatar {
  margin-right: 20rpx;
}

.avatar-container.card-avatar {
  margin-bottom: 16rpx;
}

.avatar-container.ranking-avatar {
  margin: 8rpx auto;
}

.avatar-container.participant-avatar {
  flex-shrink: 0;
  margin-right: 24rpx;
}

.avatar-container.member-avatar {
  flex-shrink: 0;
  margin-right: 20rpx;
} 