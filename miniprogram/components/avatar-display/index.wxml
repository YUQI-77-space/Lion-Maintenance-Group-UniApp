<!-- 头像显示组件 -->
<view class="avatar-container {{customClass}} avatar-{{size}} {{showBorder ? 'with-border' : ''}} {{clickable ? 'clickable' : ''}}" 
      bindtap="onAvatarClick">
  
  <!-- 加载状态 -->
  <view class="avatar-loading" wx:if="{{loading}}">
    <loading-animation size="small"></loading-animation>
  </view>
  
  <!-- 头像图片 -->
  <image 
    class="avatar-image" 
    src="{{displayAvatarUrl}}" 
    mode="aspectFill"
    lazy-load="true"
    binderror="onImageError"
    wx:if="{{!loading}}"
  />
  
  <!-- 点击提示 -->
  <view class="click-overlay" wx:if="{{clickable}}">
    <view class="click-icon">👤</view>
  </view>
</view> 