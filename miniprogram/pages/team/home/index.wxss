/* pages/team/home/index.wxss */
@import "/styles/variables.wxss";
@import "/styles/custom-navbar.wxss";

/* 禁用页面滚动，固定高度 */
page {
  height: 100vh;
  overflow: hidden;
}

.container {
  position: relative;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 200rpx; /* 为底部导航栏预留空间 */
  box-sizing: border-box;
  overflow: hidden;
}

.header {
  margin-bottom: 30rpx;
}

/* 移除原来的标题，因为已在导航栏显示 */
/* .title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-main);
} */

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

.team-slogan {
  font-size: 30rpx;
  color: var(--primary-color);
  font-weight: bold;
  margin-top: 20rpx;
  padding: 15rpx 20rpx;
  background: linear-gradient(to right, rgba(58, 117, 251, 0.05), rgba(255, 255, 255, 0.8));
  border-left: 8rpx solid var(--primary-color);
  border-radius: 8rpx;
}

.section {
  margin-bottom: 40rpx;
  background-color: var(--card-background);
  border-radius: var(--border-radius-large);
  padding: 30rpx;
  box-shadow: var(--box-shadow);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid var(--border-light);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.more-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 8rpx 16rpx;
  border: 1px solid var(--primary-color);
  border-radius: 20rpx;
  background-color: rgba(58, 117, 251, 0.05);
  transition: all 0.2s ease;
}

.more-btn:active {
  background-color: var(--primary-color);
  color: white;
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
}

.function-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.function-name {
  font-size: 28rpx;
  color: var(--text-main);
}

/* 开发者信息样式 */
.developer-info {
  position: fixed;
  bottom: 20rpx;
  right: 30rpx;
  font-size: 24rpx;
  color: var(--warning-color);
  font-family: 'KaiTi', '楷体', serif; /* 楷体 */
  opacity: 0.8;
}

/* 装饰猪猪图标 - 放置在页面下方空白区域 */
.pig-decoration {
  position: fixed;
  bottom: 138rpx; /* 在底部导航栏上方 */
  left: 50%;
  transform: translateX(-50%);
  width: 300rpx;
  height: 300rpx;
  opacity: 0.8; /* 提高透明度，让猪猪颜色更接近原图 */
  z-index: 999; /* 确保在最上层 */
  pointer-events: none; /* 不阻挡其他元素的点击 */
  transition: all 0.3s ease;
}

 