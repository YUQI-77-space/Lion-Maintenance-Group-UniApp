/* pages/team/home/more/index.wxss */
@import "/styles/variables.wxss";

page {
  background-color: var(--background-color);
}

.container {
  padding: 36rpx 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 搜索框样式 */
.search-container {
  margin-bottom: 32rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f8f9fa;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid transparent;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.search-box:focus-within {
  border-color: var(--primary-color, #007aff);
  box-shadow: 0 2rpx 16rpx rgba(0, 122, 255, 0.15);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  background: transparent;
  border: none;
  outline: none;
}

.clear-btn {
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
  transition: opacity 0.2s ease;
}

.clear-btn:active {
  opacity: 1;
}

.clear-btn image {
  width: 24rpx;
  height: 24rpx;
}

/* 功能网格 - 4列布局 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  column-gap: 24rpx;
  row-gap: 36rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
  transition: transform 0.2s ease;
}

.function-item:active {
  transform: scale(0.92);
}

.function-icon {
  width: 90rpx;
  height: 90rpx;
  margin-bottom: 16rpx;
}

.function-name {
  font-size: 30rpx;
  color: var(--text-main);
  text-align: center;
  word-break: break-all;
  line-height: 1.3;
  font-weight: 500;
}

/* 搜索无结果状态 */
.no-results-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-results-state .empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.no-results-state .empty-text {
  font-size: 32rpx;
  color: var(--text-main);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-sub-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

.reset-search-btn {
  background-color: var(--primary-color, #007aff);
  color: white;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  transition: background-color 0.2s ease;
}

.reset-search-btn:active {
  background-color: var(--primary-color-dark, #0056cc);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}


/* 响应式适配 - 小屏幕保持4列 */
@media (max-width: 400px) {
  .function-grid {
    column-gap: 16rpx;
    row-gap: 28rpx;
  }

  .function-icon {
    width: 76rpx;
    height: 76rpx;
  }

  .function-name {
    font-size: 26rpx;
  }
}
