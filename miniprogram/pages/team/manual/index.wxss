/* pages/team/manual/index.wxss */
@import "/styles/variables.wxss";

page {
  background-color: var(--background-color);
}

.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.8;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

.description {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.status-badge {
  background: linear-gradient(135deg, var(--primary-color) 0%, #5b8fff 100%);
  color: white;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 16rpx rgba(58, 117, 251, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 16rpx rgba(58, 117, 251, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 24rpx rgba(58, 117, 251, 0.4);
  }
}

