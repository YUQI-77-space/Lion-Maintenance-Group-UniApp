/* pages/team/volunteer/manage/index.wxss */
@import "/styles/variables.wxss";

/* 页面容器 - 左右分栏布局 */
.page-container {
  display: flex;
  height: 100vh;
  overflow: hidden;
  background-color: var(--background-color);
  box-sizing: border-box;
  padding-top: env(safe-area-inset-top);
  position: relative;
}

/* 左侧分类导航 */
.sidebar {
  width: 180rpx;
  flex-shrink: 0;
  background: #F5F5F5;
  border-right: 1px solid var(--border-light);
  height: 100%;
  overflow-y: hidden;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
}

.sidebar view {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 28rpx;
  position: relative;
  background: transparent;
  transition: background-color 0.2s ease;
}

.sidebar view:active {
  opacity: 0.7;
}

.sidebar view.active {
  color: var(--primary-color);
  background: var(--card-background);
  font-weight: bold;
}

.sidebar view.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 48rpx;
  background: var(--primary-color);
  border-radius: 0 3rpx 3rpx 0;
}

/* 右侧内容区域 */
.content-wrapper {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--background-color);
  position: relative;
}

/* 粘性头部：搜索框固定在页面上方，列表在其下方滚动 */
.sticky-header {
  flex-shrink: 0;
  padding: 20rpx;
  background: transparent;
}

/* 搜索框毛玻璃效果 - 使用阴影模拟半透明质感 */
.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: var(--text-main);
  padding: 0 10rpx;
  background: transparent;
}

.search-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--text-regular);
}

/* 列表滚动区域 - 必须设置高度才能滚动 */
.content {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-between;
  background-color: var(--card-background);
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--box-shadow);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 筛选标签样式 */
.filter-tabs {
  display: flex;
  background-color: var(--card-background);
  padding: 0 20rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.activity-list {
  padding: 20rpx;
}

/* 活动卡片样式 */
.activity-card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 30rpx 30rpx 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--box-shadow);
  border: 1rpx solid var(--border-light);
  /* 默认隐藏状态 */
  opacity: 0;
  transform: translateX(80rpx) translateZ(0);
  transform-origin: center top;
  transition: transform 0.2s ease-in-out;
}

/* 卡片入场动画 */
.activity-card.card-animate {
  animation: cardSlideIn 0.6s cubic-bezier(0.25, 0, 0.1, 1) forwards;
}

.activity-card.card-animate:active {
  transform: scale(0.98) translateZ(0);
}

@keyframes cardSlideIn {
  0% {
    opacity: 0;
    transform: translateX(80rpx) translateZ(0);
  }
  100% {
    opacity: 1;
    transform: translateX(0) translateZ(0);
  }
}

/* 初始加载状态样式 */
.initial-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  padding: 40rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-regular);
  font-weight: 500;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.4;
}

/* 创建按钮样式 */
.create-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #000000;
  border: 1rpx solid #000000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  z-index: 100;
  transition: all 0.2s ease;
}

.create-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.add-icon {
  width: 50rpx;
  height: 50rpx;
  filter: brightness(0) invert(1);
}

/* 操作按钮区域 */
.actions {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-left: auto;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 32rpx;
  min-height: 56rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
  border: 1rpx solid;
  margin: 0;
  white-space: nowrap;
  text-align: center;
  transition: all 0.3s ease;
  color: #ffffff;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.edit-btn {
  border-color: #191970;
  background-color: #191970;
  color: #ffffff;
}

.delete-btn {
  border-color: #B22222;
  background-color: #B22222;
  color: #ffffff;
}

/* 招募状态切换 */
.recruitment-toggle {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
}

.toggle-label {
  font-size: 26rpx;
  color: var(--text-main);
}

.toggle-label.open {
  color: #52c41a;
}

.toggle-label.closed {
  color: #ff6b6b;
}

.recruitment-switch {
  transform: scale(0.86);
}

.pending-notice {
  flex: 1;
  font-size: 26rpx;
  color: #fa8c16;
  padding: 10rpx 20rpx;
  text-align: left;
}

.countdown-banner {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  border-left: 4rpx solid #fa8c16;
  padding: 16rpx 24rpx;
  margin: 0 0 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 8rpx;
}

.countdown-label {
  font-size: 26rpx;
  color: #fa8c16;
  font-weight: 500;
}

.countdown-time {
  font-size: 28rpx;
  color: #fa8c16;
  font-weight: bold;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.header-left {
  flex: 1;
  margin-right: 20rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
}

.activity-id {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 10rpx;
}

.card-content {
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: var(--text-regular);
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
  align-self: flex-start;
  margin-top: 4rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-light);
  font-size: 26rpx;
  color: var(--text-secondary);
  width: 100%;
}

/* 状态标签样式 */
.status-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 5rpx;
  background-color: transparent;
  border: 1rpx solid;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.status-inPreparation {
  color: #FFD700;
  border-color: #FFD700;
}
.status-inPreparation .status-dot {
  background-color: #FFD700;
}
.status-inProgress {
  color: #0000FF;
  border-color: #0000FF;
}
.status-inProgress .status-dot {
  background-color: #0000FF;
}
.status-ended {
  color: #00FF00;
  border-color: #00FF00;
}
.status-ended .status-dot {
  background-color: #00FF00;
}
.status-pending {
  color: #fa8c16;
  border-color: #fa8c16;
}
.status-pending .status-dot {
  background-color: #fa8c16;
}

.activity-card.status-pending-card {
  border-color: #fa8c16;
}
.activity-card.status-inPreparation-card {
  border-color: #FFD700;
}
.activity-card.status-inProgress-card {
  border-color: #0000FF;
}
.activity-card.status-ended-card {
  border-color: #00FF00;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: var(--card-background);
  border-radius: 12rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-bottom: 1rpx solid var(--border-light);
  color: var(--text-main);
}

.modal-body {
  padding: 30rpx;
}

.ew-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  background-color: var(--card-background);
  color: var(--text-main);
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid var(--border-light);
}

.modal-btn {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
  border-radius: 0;
  background-color: var(--card-background);
}

.modal-btn.cancel {
  color: var(--text-regular);
  border-right: 1rpx solid var(--border-light);
}

.modal-btn.confirm {
  color: var(--success-color);
}

/* 删除按钮样式 - 更新 */
.action-footer {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid var(--border-light);
}

.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--danger-color);
  color: var(--text-white);
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  line-height: 1.5;
  margin: 0;
}

.delete-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

/* 删除按钮样式 */
.delete-btn-container {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(245, 108, 108, 0.9);
  border-radius: 10rpx;
  padding: 10rpx 20rpx;
  z-index: 10;
}

.delete-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 5rpx;
}

.delete-text {
  font-size: 24rpx;
  color: var(--text-white);
}

/* 初始加载状态样式 */
.initial-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  padding: 40rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}