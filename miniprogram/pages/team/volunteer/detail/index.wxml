<!-- pages/team/volunteer/detail/index.wxml -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <loading-animation size="large"></loading-animation>
  </view>
  
  <block wx:if="{{!loading && activity}}">
    <!-- 活动标题 -->
    <view class="header-card">
      <view class="header-left">
        <view class="title">{{activity.title}}</view>
        <view class="activity-id">编号: {{activity.activityId}}</view>
      </view>
      <view class="status-tag status-{{activity.activityStatus}}">
        <view class="status-dot"></view>
        <text>{{activity.activityStatusText}}</text>
      </view>
    </view>
  
    <!-- 活动信息 -->
    <view class="info-section">
      <view class="info-item">
        <view class="info-label">活动时间</view>
        <view class="info-value">{{formattedStartTime}} 至 {{formattedEndTime}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">活动地点</view>
        <view class="info-value">{{activity.location}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">活动时长</view>
        <view class="info-value">{{activity.duration}}小时</view>
      </view>
      <view class="info-item">
        <view class="info-label">志愿时长</view>
        <view class="info-value">{{activity.volunteerHours || activity.duration}}小时</view>
      </view>
      <view class="info-item">
        <view class="info-label">报名人数</view>
        <view class="info-value">{{activity.numberOfVolunteers}}/{{activity.volunteerCount}}人</view>
      </view>

      <view class="info-item">
        <view class="info-label">创建者</view>
        <view class="info-value">{{activity.creatorName || '未知'}}</view>
      </view>
    </view>
    
    <!-- 活动描述 -->
    <view class="description-section">
      <view class="section-title">活动详情</view>
      <view class="description-content">{{activity.description || '暂无详细描述'}}</view>
    </view>
    
    <!-- 参与者列表 -->
    <view class="detail-card participants-section" wx:if="{{userRole === 'leader'}}">
      <view class="participants-header">
        <view class="section-title">参与者列表</view>
        <view class="participant-header-actions" wx:if="{{isFromManagePage}}">
          <view class="participant-action-btn participant-action-btn--import"
                wx:if="{{activity.activityStatus !== 'ended'}}"
                bindtap="showImportVolunteersModal">
            导入志愿者
          </view>
          <view class="participant-action-btn participant-action-btn--export"
                wx:if="{{activity.numberOfVolunteers > 0}}"
                bindtap="exportParticipants">
            导出名单
          </view>
          <view class="participant-action-btn participant-action-btn--ew"
                wx:if="{{activity.activityStatus === 'ended' && participants.length > 0}}"
                bindtap="openSetPerUserEWModal">
            设置EW值
          </view>
        </view>
      </view>
      <view class="participants-list">
        <block wx:if="{{participants.length > 0}}">
          <view class="participant-item" wx:for="{{participants}}" wx:key="openid">
            <!-- Col 1: Avatar -->
            <avatar-display 
              userInfo="{{item}}" 
              openid="{{item.openid}}"
              size="medium"
              showBorder="{{true}}"
              customClass="participant-avatar"
            />
            
            <!-- Col 2: Name & StudentId -->
            <view class="info-column">
              <text class="info-text name">{{item.nickName || 'N/A'}}</text>
              <text class="info-text student-id">{{item.studentId || '未填'}}</text>
            </view>
            
            <!-- Col 3: Division -->
            <view class="division-column">
              <text class="info-text division">{{item.feedback || '未填写分工信息'}}</text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="empty-participants">
            <text>暂无参与者信息</text>
          </view>
        </block>
      </view>
    </view>
    
  </block>
  
  <!-- 活动不存在 -->
  <view class="not-found" wx:if="{{!loading && !activity}}">
    <text>活动不存在或已被删除</text>
  </view>
</view>



