<!-- 导入志愿者底部浮窗 -->
<view class="import-sheet" wx:if="{{showImportModal}}" catchtouchmove="preventTouch">
  <view class="import-sheet-mask" bindtap="closeImportModal" catchtouchmove="preventTouch"></view>
  <view class="import-sheet-panel {{importSheetClosing ? 'closing' : ''}}">
    <view class="sheet-header">
      <view class="sheet-handle"></view>
      <view class="sheet-title-row">
        <view class="sheet-title-group">
          <text class="sheet-title">导入志愿者</text>
          <text class="sheet-subtitle">挑选组员加入活动，支持多选</text>
        </view>
        <text class="sheet-count">已选 {{pendingSelectionCount}} 人</text>
      </view>
    </view>

    <view class="sheet-capacity">
      <text>剩余名额：{{((activity && activity.volunteerCount) || 0) - ((activity && activity.numberOfVolunteers) || 0) - selectedMembers.length}} 人</text>
      <text class="sheet-capacity-tip">已参与 {{(activity && activity.numberOfVolunteers) || 0}} / 目标 {{(activity && activity.volunteerCount) || 0}}</text>
    </view>

    <scroll-view class="sheet-members" scroll-y="true" enable-flex="true" show-scrollbar="{{false}}" enhanced="true">
      <view class="import-loading" wx:if="{{importLoading}}">
        <loading-animation size="default"></loading-animation>
      </view>
      <block wx:else>
        <block wx:if="{{filteredMembers.length > 0}}">
          <view class="member-card {{item.isSelected ? 'selected' : ''}} {{item.isParticipant ? 'disabled' : ''}}"
                wx:for="{{filteredMembers}}"
                wx:key="openid">
            <avatar-display 
              userInfo="{{item}}" 
              openid="{{item.openid}}"
              size="small"
              showBorder="{{false}}"
              customClass="member-card-avatar"
            />
            <view class="member-card-info">
              <view class="member-card-name">
                {{item.displayName || item.nickName || '未命名'}}
                <text class="member-role-tag" wx:if="{{item.role === 'leader'}}">组长</text>
              </view>
              <view class="member-card-meta">
                <text class="member-role-text">{{item.role === 'leader' ? '组长' : '成员'}}</text>
                <text class="member-extra" wx:if="{{item.isParticipant}}">已在活动中</text>
              </view>
            </view>
            <view class="member-card-action {{item.isParticipant ? 'locked' : ''}}">
              <view class="pill-button {{item.isSelected ? 'selected' : ''}}"
                    data-openid="{{item.openid}}"
                    catchtap="toggleMemberSelection">
                <text>{{item.isSelected ? '✓' : '+'}}</text>
              </view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="empty-members modern">
            <text>暂无可导入的成员</text>
          </view>
        </block>
      </block>
    </scroll-view>
  </view>

  <view class="selected-layer {{hasPendingSelections ? 'show' : ''}}">
    <view class="selected-panel {{showSelectedPanel ? 'show' : ''}}" catchtouchmove="preventTouch">
      <view class="selected-panel-header">
        <view class="panel-title">已选志愿者</view>
        <text class="panel-clear" wx:if="{{selectedMembers.length > 0}}" catchtap="clearAllSelected">清空</text>
      </view>
      <view class="selected-list-wrapper">
        <scroll-view class="selected-list" scroll-y="true" enable-flex="true" show-scrollbar="{{false}}" enhanced="true">
          <block wx:if="{{selectedMemberList.length > 0}}">
            <view class="selected-item" wx:for="{{selectedMemberList}}" wx:key="openid">
              <avatar-display 
                userInfo="{{item}}" 
                openid="{{item.openid}}"
                size="small"
                showBorder="{{false}}"
                customClass="selected-avatar"
              />
              <view class="selected-item-info">
                <view class="selected-name">
                  {{item.displayName || item.nickName || '未命名'}}
                  <text class="member-role-tag" wx:if="{{item.role === 'leader'}}">组长</text>
                </view>
                <view class="selected-meta">
                  <text>{{item.role === 'leader' ? '组长' : '成员'}}</text>
                </view>
              </view>
              <view class="remove-selected-btn" data-openid="{{item.openid}}" catchtap="removeSelectedMember">
                <view class="remove-icon"></view>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="empty-selected">
              <text>还没有选择志愿者</text>
            </view>
          </block>
        </scroll-view>
      </view>
    </view>

    <view class="selected-bar" catchtouchmove="preventTouch">
      <view class="selected-main-area" bindtap="toggleSelectedPanel">
        <view class="selected-bar-text">
          <text class="selected-bar-label">已选志愿者</text>
          <text class="selected-bar-count">{{pendingSelectionCount}} 人待导入</text>
        </view>
        <view class="selected-avatars">
          <block wx:for="{{selectedMemberPreview}}" wx:key="openid">
            <avatar-display 
              userInfo="{{item}}" 
              openid="{{item.openid}}"
              size="small"
              showBorder="{{false}}"
              customClass="selected-avatar"
            />
          </block>
          <view class="selected-extra-pill" wx:if="{{selectedMemberExtraCount > 0}}">
            +{{selectedMemberExtraCount}}
          </view>
        </view>
        <view class="selected-bar-arrow {{showSelectedPanel ? 'expanded' : ''}}"></view>
      </view>
      <view class="selected-confirm-area {{importLoading || !hasPendingSelections ? 'disabled' : ''}}"
            catchtap="handleSelectedConfirm">
        {{importLoading ? '导入中...' : '确认'}}
      </view>
    </view>
  </view>
</view>

<!-- 新增：按人设置EW的弹窗（全屏遮罩，防止点击穿透） -->
<view class="per-ew-modal" wx:if="{{showPerUserEWModal}}" catchtouchmove="preventTouch" catchtap="preventTouch">
  <view class="per-ew-mask" catchtouchmove="preventTouch" catchtap="preventTouch"></view>
  <view class="per-ew-content" catchtap="preventTouch" catchtouchmove="preventTouch">
    <view class="per-ew-header">
      <text>设置本次活动各志愿者EW</text>
      <view class="per-ew-close" bindtap="closeSetPerUserEWModal">×</view>
    </view>
    <scroll-view class="per-ew-list" scroll-y="true">
      <view class="per-ew-item" wx:for="{{participants}}" wx:key="openid">
        <view class="per-ew-left">
          <text class="per-ew-name">{{item.nickName || 'N/A'}}</text>

        </view>
        <input class="per-ew-input" type="digit" placeholder="0-50" data-openid="{{item.openid}}" value="{{perUserEWMap[item.openid] || ''}}" bindinput="onPerUserEWInput" />
      </view>
    </scroll-view>
    <view class="per-ew-footer">
      <button class="per-ew-cancel" bindtap="closeSetPerUserEWModal">取消</button>
      <button class="per-ew-confirm" bindtap="confirmSetPerUserEW">确认提交</button>
    </view>
  </view>
</view>