<!--pages/home/team-spirit/index.wxml-->
<view class="container">
  <!-- 图片网格 -->
  <view class="image-grid">
    <block wx:for="{{teamSpirit}}" wx:key="id">
      <view class="image-item">
        <skeleton-image
          class="skeleton-image"
          src="{{item.url}}"
          mode="aspectFill"
          lazy-load="{{false}}"
          placeholder-color="#e8ecef"
          bindimageloadcomplete="onImageLoadComplete"
        />
      </view>
    </block>

    <!-- 骨架屏占位 - 首次加载时显示 -->
    <block wx:if="{{loading && teamSpirit.length === 0}}">
      <view class="image-item skeleton-item" wx:for="{{skeletonCount}}" wx:key="skeleton-{{index}}">
        <view class="skeleton-shimmer"></view>
      </view>
    </block>
  </view>

  <!-- 加载状态 -->
  <view class="loading-section" wx:if="{{loading && teamSpirit.length > 0}}">
    <loading-animation size="default"></loading-animation>
  </view>

  <!-- 没有更多数据提示 -->
  <view class="no-more" wx:if="{{!hasMore && teamSpirit.length > 0}}">
    <text class="no-more-text">— 已加载全部 —</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && teamSpirit.length === 0 && isInitialized}}">
    <text class="empty-text">暂无团队风采图片</text>
  </view>
</view>
