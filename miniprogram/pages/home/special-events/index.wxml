<!--pages/home/special-events/index.wxml-->
<view class="special-events-container">
  <!-- 图片网格 -->
  <view class="events-grid">
    <block wx:for="{{specialEvents}}" wx:key="id">
      <view class="event-item">
        <skeleton-image
          class="skeleton-image"
          src="{{item.url}}"
          mode="aspectFill"
          lazy-load="{{false}}"
          placeholder-color="#f0f0f0"
          bindimageloadcomplete="onImageLoadComplete"
        />
      </view>
    </block>

    <!-- 骨架屏占位 - 首次加载时显示 -->
    <block wx:if="{{loading && specialEvents.length === 0}}">
      <view class="event-item skeleton-item" wx:for="{{skeletonCount}}" wx:key="skeleton-{{index}}">
        <view class="skeleton-shimmer"></view>
      </view>
    </block>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading && specialEvents.length > 0}}">
    <loading-animation size="default"></loading-animation>
  </view>

  <!-- 没有更多数据提示 -->
  <view class="no-more" wx:if="{{!hasMore && specialEvents.length > 0}}">
    <text class="no-more-text">— 已加载全部 —</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{!loading && specialEvents.length === 0 && isInitialized}}">
    <image class="empty-image" src="{{iconEmpty}}" mode="aspectFit"></image>
    <text class="empty-text">暂无特色活动图片</text>
  </view>
</view>
