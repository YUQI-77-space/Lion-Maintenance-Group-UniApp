/* pages/login/index.wxss */
@import "/styles/variables.wxss";

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--background-color);
}

/* 自动登录加载界面：简化为干净布局 */
.auto-login-container { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  justify-content: center; 
  height: 100vh; 
  padding: 60rpx; 
}

.logo-wrapper { 
  position: relative; 
  margin-bottom: 40rpx; 
}

.logo { 
  width: 160rpx; 
  height: 160rpx; 
  border-radius: 50%; 
  background: var(--card-background); 
  border: 2rpx solid var(--border-light); 
  padding: 16rpx; 
}

.logo-pulse { 
  display: none; 
}

.loading-text { 
  font-size: 30rpx; 
  color: var(--text-regular); 
  margin-bottom: 24rpx; 
}

.loading-animation { 
  display: flex; 
  gap: 10rpx; 
}

.loading-dot { 
  width: 16rpx; 
  height: 16rpx; 
  border-radius: 50%; 
  background: var(--border-light); 
}

/* 主内容容器 */
.container > block:not(:first-child) { 
  flex: 1; 
  padding: 24rpx; 
}

/* 步骤指示器：线框风 */
.step-indicator { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  margin: 16rpx 0 24rpx; 
}

.step { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
}

.step-number {
  width: 56rpx; 
  height: 56rpx; 
  border-radius: 50%;
  border: 2rpx solid var(--border-light); 
  color: var(--text-secondary);
  display: flex; 
  align-items: center; 
  justify-content: center; 
  font-size: 26rpx; 
  font-weight: 600;
}

.step.active .step-number { 
  border-color: var(--primary-color); 
  color: var(--primary-color); 
}

.step-name { 
  font-size: 24rpx; 
  color: var(--text-secondary); 
  margin-top: 6rpx; 
}

.step.active .step-name { 
  color: var(--text-main); 
}

.step-line { 
  width: 100rpx; 
  height: 2rpx; 
  background: var(--border-light); 
  margin: 0 18rpx 24rpx; 
}

/* 授权容器：线框卡片 */
.auth-container { 
  background: var(--card-background); 
  border: 2rpx solid var(--border-light); 
  border-radius: 16rpx; 
  padding: 28rpx; 
}

.section-header { 
  text-align: center; 
  margin-bottom: 20rpx; 
}

.section-title { 
  font-size: 34rpx; 
  font-weight: 700; 
  color: var(--text-main); 
}

.section-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* 表单区域 */
.form-section { 
  margin-bottom: 20rpx; 
}

.avatar-container { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  margin: 20rpx 0 24rpx; 
}

.avatar-wrapper { 
  background: transparent; 
  width: 140rpx; 
  height: 140rpx; 
  border-radius: 50%; 
  position: relative; 
}

.avatar { 
  width: 140rpx; 
  height: 140rpx; 
  border-radius: 50%; 
  background: var(--background-color); 
  border: 2rpx solid var(--border-light); 
}

.avatar-overlay { 
  display: none; 
}

.avatar-tips { 
  margin-top: 10rpx; 
  font-size: 24rpx; 
  color: var(--text-secondary); 
}

.form-item { 
  margin-bottom: 20rpx; 
}

.form-label { 
  font-size: 26rpx; 
  color: var(--text-main); 
  margin-bottom: 10rpx; 
  font-weight: 600; 
  display: flex; 
  align-items: center; 
  gap: 10rpx; 
}

.label-icon { 
  font-size: 28rpx; 
}

.label-text { 
  flex: 1; 
}

.form-label.required .label-text::before { 
  content: '*'; 
  color: var(--danger-color); 
  margin-right: 6rpx; 
}

.label-subtitle {
  font-size: 22rpx;
  color: var(--text-disabled);
  font-weight: normal;
}

.input-wrapper { 
  position: relative; 
}

.paste-hint {
  position: absolute;
  right: 18rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: var(--text-disabled);
  pointer-events: none;
  z-index: 1;
}

.form-input {
  width: 100%; 
  height: 86rpx; 
  border: 2rpx solid var(--border-light); 
  border-radius: 12rpx;
  padding: 0 18rpx; 
  font-size: 28rpx; 
  color: var(--text-main); 
  background: var(--card-background);
}

.input-decoration { 
  display: none; 
}

.form-input:focus { 
  border-color: var(--primary-color); 
}



/* 隐私协议区域 */
.privacy-section { 
  margin: 20rpx 0; 
}

.privacy-agreement { 
  display: flex; 
  align-items: center; 
  padding: 16rpx; 
  background: transparent; 
  border-radius: 10rpx; 
  border: 2rpx solid var(--border-light); 
}

.privacy-text { 
  margin-left: 12rpx; 
  font-size: 24rpx; 
  color: var(--text-secondary); 
}

.privacy-link { 
  color: var(--primary-color); 
  text-decoration: underline; 
  margin-left: 6rpx; 
}

/* 操作按钮：描边主按钮 */
.action-section { 
  margin-top: 24rpx; 
}

.primary-btn {
  width: 100%; 
  height: 86rpx; 
  border-radius: 12rpx; 
  font-size: 30rpx; 
  font-weight: 600;
  border: 2rpx solid var(--primary-color); 
  background: transparent; 
  color: var(--primary-color);
  padding: 0;
  display: flex; 
  align-items: center; 
  justify-content: center;
}

.primary-btn::after { 
  border: none; 
}

.primary-btn[disabled] { 
  border-color: var(--border-light); 
  color: var(--text-secondary); 
}

.secondary-btn {
  width: 100%;
  height: 86rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx dashed var(--primary-color);
  background: rgba(0,0,0,0.02);
  color: var(--primary-color);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.secondary-btn::after {
  border: none;
}

/* 网络提示信息样式 */
.network-warning {
  margin-top: 24rpx;
  padding: 16rpx;
  text-align: center;
}

.warning-text {
  font-size: 22rpx;
  color: #e74c3c;
  line-height: 1.4;
  font-weight: 500;
}

 