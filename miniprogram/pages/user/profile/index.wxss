/* pages/user/profile/index.wxss */
@import "/styles/variables.wxss";
@import "/styles/custom-navbar.wxss";

/* 页面根容器 */
page {
  height: 100vh;
  overflow: hidden;
  background: #EEF2F8;
}

.profile-page {
  position: relative;
  background: var(--bg-card);
  /* padding-top 通过动态 style 设置以适配不同设备 */
}

/* ==================== 沉浸式头部区域 ==================== */
.profile-header {
  position: relative;
  background: #EEF2F8;
  padding: 24rpx 32rpx 48rpx;
  overflow: hidden;
}

/* 暗纹背景（浅色圆点） */
.header-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.04) 1rpx, transparent 1rpx);
  background-size: 24rpx 24rpx;
  pointer-events: none;
}

/* 退出按钮 */
.header-logout {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border: 2rpx solid var(--danger);
  border-radius: 8rpx;
  background: transparent;
}

.header-logout::after {
  border: none;
}

.logout-text {
  font-size: 24rpx;
  color: var(--danger);
}

/* 用户信息区域 */
.header-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
  padding-top: 20rpx;
}

.avatar-container {
  margin-bottom: 20rpx;
}

.avatar-container .profile-avatar {
  border: 4rpx solid #FFFFFF !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12) !important;
}

.user-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.role-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: 24rpx;
}

/* 部门选择器 */
.header-department {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.department-picker {
  width: auto;
  max-width: 320rpx;
}

.picker-content {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(0, 0, 0, 0.04);
  border: 1rpx solid var(--border);
  border-radius: 999rpx;
}

.picker-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* ==================== 功能入口区域 ==================== */
.profile-content {
  position: relative;
  background: #F0F2F7;
  padding: 32rpx 24rpx;
  margin-top: -24rpx;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 340rpx);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* 功能列表 */
.function-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.function-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.item-icon { 
  width: 48rpx; 
  height: 48rpx; 
}

.item-content { 
  flex: 1; 
}

.item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.item-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.item-arrow { 
  width: 32rpx; 
  height: 32rpx; 
  opacity: 0.5; 
}

/* 计数徽章 */
.item-badge {
  min-width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 14rpx;
  background: var(--danger);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 999rpx;
  text-align: center;
  margin-right: 8rpx;
}
