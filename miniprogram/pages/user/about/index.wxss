/* pages/user/about/index.wxss */
@import "/styles/variables.wxss";

.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: var(--background-color);
  display: flex;
  flex-direction: column;
}

/* Logo部分 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.logo {
  width: 240rpx;
  height: 240rpx;
  border-radius: 20rpx;
}

.about-slogan {
  margin-top: 30rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  text-align: center;
  padding: 20rpx;
  background-color: rgba(58, 117, 251, 0.1);
  border-radius: 10rpx;
  width: 90%;
  box-shadow: var(--box-shadow);
}

/* 介绍部分 */
.intro-section {
  margin: 30rpx 0;
  padding: 30rpx;
  background-color: var(--card-background);
  border-radius: 12rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background-color: var(--primary-color);
  border-radius: 4rpx;
}

.intro-content {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.8;
  text-align: justify;
  white-space: pre-wrap;
}

/* 新增：段落与枚举列表样式 */
.intro-paragraph {
  margin-bottom: 12rpx;
}

.intro-list {
  margin: 10rpx 0 16rpx;
}

.intro-list-item {
  display: flex;
  align-items: flex-start;
  margin: 10rpx 0;
}

.intro-list-item .dot {
  width: 32rpx;
  display: inline-block;
  color: var(--primary-color);
  font-weight: bold;
}

.intro-list-item .text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.8;
}

/* 联系方式部分 */
.contact-section {
  margin: 30rpx 0;
  padding: 30rpx;
  background-color: var(--card-background);
  border-radius: 12rpx;
}

.contact-item {
  display: flex;
  margin-bottom: 20rpx;
}

.contact-item:last-child {
  margin-bottom: 0;
}

.contact-label {
  font-size: 28rpx;
  color: var(--text-regular);
  min-width: 160rpx;
}

.contact-value {
  font-size: 28rpx;
  color: var(--text-main);
  flex: 1;
}

/* 版权信息 */
.footer {
  margin-top: auto;
  padding: 30rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 可复制文本样式 */
.copyable-text {
  color: var(--primary-color);
  text-decoration: underline;
  text-decoration-style: dashed;
  text-underline-offset: 4rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.copyable-text:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* 开发者信息样式 */
.developer-info {
  text-align: right;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--warning-color);
  font-family: 'KaiTi', '楷体', serif; /* 楷体 */
  opacity: 0.8;
}

