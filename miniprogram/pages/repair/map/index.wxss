@import "/styles/variables.wxss";

page {
  background-color: var(--background-color);
  color: var(--text-main);
}

.container {
  padding: 24rpx;
}

.map-tip {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--card-background);
  border: 1px solid var(--border-light);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.map-card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  box-shadow: var(--box-shadow);
  margin-bottom: 24rpx;
  border: 1px solid var(--border-light);
}

.cat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
}

.cat-name {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: bold;
}

.cat-body {
  padding: 0 24rpx 8rpx 24rpx;
}

.sub-card {
  border-top: 1px solid var(--border-light);
}

.sub-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.sub-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}

.types {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.type-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background-color: var(--status-secondary-bg);
  color: var(--secondary-color);
  border: 1px solid var(--secondary-color);
  font-size: 24rpx;
}

.arrow {
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid var(--text-secondary);
  border-bottom: 4rpx solid var(--text-secondary);
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.arrow.small {
  width: 14rpx;
  height: 14rpx;
}

.arrow.expanded {
  transform: rotate(-135deg);
}


