/* ============================================
   极简线框风格 - 全局样式变量
   核心理念：线框 + 极简 + 功能导向
   ============================================ */

page {
  /* === 核心色彩 === */
  --primary: #0000CD;        /* 组织核心色 - 深蓝 */
  --border-color: #00008B;   /* 线框色 - 深蓝描边 */

  /* === 背景色彩 === */
  --bg-page: #F7F7F7;       /* 页面背景 */
  --bg-card: #FFFFFF;        /* 卡片背景 */

  /* === 边框色彩 === */
  --border: #E0E0E0;         /* 辅助边框 - 浅灰 */

  /* === 文字色彩 === */
  --text-primary: #1A1A1A;  /* 主要文字 */
  --text-secondary: #666666; /* 次要文字 */
  --text-muted: #999999;     /* 弱化文字 */

  /* === 状态色彩 === */
  --success: #52C41A;        /* 成功 */
  --warning: #FAAD14;        /* 警告 */
  --danger: #FF4D4F;         /* 危险 */
  --info: #1890FF;           /* 信息 */

  /* === 维修任务状态色 === */
  --maintenance-pending-color: #FA8C16;      /* 待受理 - 橙色 */
  --maintenance-inProgress-color: #1890FF;  /* 进行中 - 蓝色 */
  --maintenance-completed-color: #52C41A;   /* 已完成 - 绿色 */
  --maintenance-cancelled-color: #000000;   /* 已撤销 - 黑色 */

  /* === 字体大小 === */
  --font-title: 36rpx;       /* 标题 */
  --font-subtitle: 30rpx;     /* 小标题 */
  --font-body: 28rpx;         /* 正文 */
  --font-caption: 24rpx;      /* 辅助文字 */
  --font-hint: 22rpx;         /* 提示文字 */

  /* === 间距 === */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* === 圆角 === */
  --radius-card: 16rpx;      /* 卡片圆角 */
  --radius-btn: 8rpx;         /* 按钮圆角 */
  --radius-tag: 4rpx;          /* 标签圆角 */
  --radius-image: 12rpx;      /* 图片圆角 */

  /* === 兼容旧文字颜色 === */
  --text-main: var(--text-primary);
  --text-regular: var(--text-secondary);
  --text-placeholder: var(--text-muted);
  --background-color: var(--bg-page);
  --card-background: var(--bg-card);
  --border-light: var(--border);

  /* === 兼容旧按钮样式（逐步废弃） === */
  --button-primary-bg: transparent;
  --button-primary-text: var(--primary);
  --button-secondary-bg: transparent;
  --button-secondary-text: var(--text-secondary);
  --button-secondary-border: var(--border);
  --button-disabled-bg: var(--border);
  --button-disabled-text: var(--text-muted);
  --button-danger-bg: transparent;
  --button-danger-text: var(--danger);

  /* === 兼容旧状态色（逐步废弃） === */
  --success-color: var(--success);
  --warning-color: var(--warning);
  --danger-color: var(--danger);
  --info-color: var(--info);
  --secondary-color: #1890FF;  /* 兼容旧的蓝色 */

  /* === 兼容旧阴影（已废弃，仅保留边框） === */
  --box-shadow: none;
  --box-shadow-light: none;
  --box-shadow-medium: none;
  --box-shadow-heavy: none;

  /* === 兼容旧间距 === */
  --spacing-large: var(--space-md);
  --spacing-medium: var(--space-sm);
  --spacing-small: var(--space-xs);

  /* === 兼容旧圆角 === */
  --border-radius-large: var(--radius-card);
  --border-radius-medium: var(--radius-btn);
  --border-radius-small: var(--radius-tag);

  /* === 兼容旧文字大小 === */
  --font-size-large: 18px;
  --font-size-medium: 16px;
  --font-size-normal: 14px;
  --font-size-small: 12px;
}
